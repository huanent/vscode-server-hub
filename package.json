{
  "name": "server-hub",
  "displayName": "ServerHub",
  "description": "Manage and connect to ssh mysql server and more..",
  "version": "1.5.0",
  "engines": {
    "vscode": "^1.125.0"
  },
  "license": "MIT",
  "publisher": "huanent",
  "icon": "resources/logo.png",
  "main": "./out/extension.js",
  "extensionKind": [
    "ui"
  ],
  "homepage": "https://github.com/huanent/vscode-server-hub",
  "repository": {
    "type": "github",
    "url": "https://github.com/huanent/vscode-server-hub"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "server-hub.editor",
        "displayName": "ServerHub",
        "selector": [
          {
            "filenamePattern": "*.server-hub"
          }
        ],
        "priority": "option"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "server-hub",
          "title": "ServerHub",
          "icon": "$(server)"
        }
      ]
    },
    "views": {
      "server-hub": [
        {
          "id": "server-hub.servers",
          "name": "ServerHub",
          "icon": "$(server)"
        }
      ]
    },
    "commands": [
      {
        "command": "server-hub.addServer",
        "title": "Add",
        "icon": "$(add)"
      },
      {
        "command": "server-hub.importServers",
        "title": "Import",
        "icon": "$(cloud-download)"
      },
      {
        "command": "server-hub.exportServers",
        "title": "Export",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "server-hub.exportServer",
        "title": "Export",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "server-hub.connectServer",
        "title": "Connect",
        "icon": "$(run-compact)"
      },
      {
        "command": "server-hub.copyHost",
        "title": "Copy Address",
        "icon": "$(copy)"
      },
      {
        "command": "server-hub.editServer",
        "title": "Edit Connection",
        "icon": "$(edit)"
      },
      {
        "command": "server-hub.renameGroup",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "server-hub.deleteServer",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "server-hub.openSftp",
        "title": "Open SFTP",
        "icon": "$(folder)"
      },
      {
        "command": "server-hub.searchServers",
        "title": "Search Servers",
        "icon": "$(search)"
      },
      {
        "command": "server-hub.clearServerSearch",
        "title": "Clear Server Search",
        "icon": "$(clear-all)"
      },
      {
        "command": "server-hub.executeMysqlSql",
        "title": "Execute SQL",
        "icon": "$(play)"
      }
    ],
    "keybindings": [
      {
        "command": "server-hub.executeMysqlSql",
        "key": "f5",
        "when": "editorTextFocus && editorLangId == sql && server-hub.mysqlSqlEditorActive"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "server-hub.executeMysqlSql",
          "when": "editorLangId == sql && server-hub.mysqlSqlEditorActive",
          "group": "navigation@1"
        },
        {
          "command": "server-hub.openSftp",
          "when": "activeWebviewPanelId == server-hub.editor && resourceFilename == sshTerminal.server-hub",
          "group": "navigation@1"
        }
      ],
      "view/title": [
        {
          "command": "server-hub.clearServerSearch",
          "when": "view == server-hub.servers && server-hub.serverFilterActive",
          "group": "navigation@1"
        },
        {
          "command": "server-hub.searchServers",
          "when": "view == server-hub.servers",
          "group": "navigation@2"
        },
        {
          "command": "server-hub.importServers",
          "when": "view == server-hub.servers",
          "group": "1_transfer@1"
        },
        {
          "command": "server-hub.exportServers",
          "when": "view == server-hub.servers",
          "group": "1_transfer@2"
        },
        {
          "command": "server-hub.addServer",
          "when": "view == server-hub.servers",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "server-hub.renameGroup",
          "when": "view == server-hub.servers && viewItem == serverGroup",
          "group": "1_modification"
        },
        {
          "command": "server-hub.connectServer",
          "when": "view == server-hub.servers && (viewItem == sshServer || viewItem == mysqlServer || viewItem == containerServer)",
          "group": "inline"
        },
        {
          "command": "server-hub.editServer",
          "when": "view == server-hub.servers && !listMultiSelection && (viewItem == sshServer || viewItem == mysqlServer || viewItem == containerServer)",
          "group": "1_modification"
        },
        {
          "command": "server-hub.copyHost",
          "when": "view == server-hub.servers && !listMultiSelection && (viewItem == sshServer || viewItem == mysqlServer || viewItem == containerServer)",
          "group": "1_modification@2"
        },
        {
          "command": "server-hub.exportServer",
          "when": "view == server-hub.servers && (viewItem == sshServer || viewItem == mysqlServer || viewItem == containerServer)",
          "group": "1_modification@3"
        },
        {
          "command": "server-hub.deleteServer",
          "when": "view == server-hub.servers && (viewItem == sshServer || viewItem == mysqlServer || viewItem == containerServer)",
          "group": "2_delete"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run prepare:webview && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepare:webview": "mkdir -p resources/xterm resources/codicons && cp node_modules/@xterm/xterm/css/xterm.css node_modules/@xterm/xterm/lib/xterm.js node_modules/@xterm/addon-fit/lib/addon-fit.js resources/xterm/ && cp node_modules/@vscode/codicons/dist/codicon.css node_modules/@vscode/codicons/dist/codicon.ttf resources/codicons/",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "publish": "vsce publish",
    "prepack": "npm prune",
    "pack": "vsce pack"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/ssh2": "^1.15.5",
    "@types/vscode": "^1.125.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "mysql2": "^3.23.0",
    "ssh2": "^1.17.0"
  }
}
